<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="NetSuite Endpoints" require-authentication="false">

    <parameter name="editNsRestletConfigId"/>

    <transition name="saveNsRestletConfig">
        <actions>
            <set field="nsRestletConfigId" from="nsRestletConfigId?.trim()"/>
            <set field="nsDescription" from="nsDescription?.trim()"/>
            <set field="nsEndpointUrl" from="nsEndpointUrl?.trim()"/>
            <set field="nsHttpMethod" from="nsHttpMethod?.trim()?.toUpperCase()"/>
            <set field="nsAuthConfigId" from="nsAuthConfigId?.trim()"/>
            <set field="nsHeadersJson" from="nsHeadersJson?.trim()"/>
            <set field="nsConnectTimeoutSeconds" from="nsConnectTimeoutSeconds?.trim()"/>
            <set field="nsReadTimeoutSeconds" from="nsReadTimeoutSeconds?.trim()"/>
            <set field="nsIsActive" from="nsIsActive?.trim()?.toUpperCase()"/>

            <if condition="!nsRestletConfigId">
                <message type="error" text="Endpoint Config ID is required."/>
                <return error="true"/>
            </if>
            <if condition="!nsEndpointUrl">
                <message type="error" text="Endpoint URL is required."/>
                <return error="true"/>
            </if>
            <if condition="!['POST','PUT','GET'].contains(nsHttpMethod ?: 'POST')">
                <message type="error" text="HTTP Method must be POST, PUT, or GET."/>
                <return error="true"/>
            </if>
            <if condition="!nsAuthConfigId">
                <message type="error" text="Auth Config ID is required. Configure auth in Settings -> NetSuite Auth."/>
                <return error="true"/>
            </if>

            <script><![CDATA[
                Integer connectTimeout = nsConnectTimeoutSeconds ? (nsConnectTimeoutSeconds as Integer) : 30
                Integer readTimeout = nsReadTimeoutSeconds ? (nsReadTimeoutSeconds as Integer) : 60
                if (connectTimeout <= 0) connectTimeout = 30
                if (readTimeout <= 0) readTimeout = 60

                if (nsHeadersJson) {
                    try {
                        def parsedHeaders = new groovy.json.JsonSlurper().parseText(nsHeadersJson)
                        if (!(parsedHeaders instanceof Map)) {
                            ec.message.addError("Headers JSON must be a JSON object.")
                            return
                        }
                    } catch (Exception e) {
                        ec.message.addError("Headers JSON is invalid: ${e.message}")
                        return
                    }
                }

                def authCfg = ec.entity.find("darpan.reconciliation.NsAuthConfig")
                        .condition("nsAuthConfigId", nsAuthConfigId)
                        .useCache(false)
                        .one()
                if (!authCfg) {
                    ec.message.addError("NsAuthConfig ${nsAuthConfigId} not found. Create it in Settings -> NetSuite Auth.")
                    return
                }
                if ((authCfg.isActive ?: "Y").toString().equalsIgnoreCase("N")) {
                    ec.message.addError("NsAuthConfig ${nsAuthConfigId} is inactive.")
                    return
                }

                Map endpointMap = [
                        nsRestletConfigId    : nsRestletConfigId,
                        description          : nsDescription,
                        endpointUrl          : nsEndpointUrl,
                        httpMethod           : nsHttpMethod ?: 'POST',
                        nsAuthConfigId       : nsAuthConfigId,
                        headersJson          : nsHeadersJson,
                        connectTimeoutSeconds: connectTimeout,
                        readTimeoutSeconds   : readTimeout,
                        isActive             : nsIsActive ?: 'Y',
                        // Clear legacy auth fields for newly saved endpoint rows.
                        authType             : null,
                        username             : null,
                        password             : null,
                        apiToken             : null,
                        tokenUrl             : null,
                        clientId             : null,
                        certId               : null,
                        privateKeyPem        : null,
                        scope                : null
                ]
                context.endpointMap = endpointMap
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <script><![CDATA[
                String entityName = "darpan.reconciliation.NsRestletConfig"
                String groupName = ec.entity.getEntityGroupName(entityName)
                def datasourceFactory = groupName ? ec.entity.getDatasourceFactory(groupName) : null
                if (!datasourceFactory) {
                    ec.message.addError("Could not resolve datasource for ${entityName}.")
                    return
                }
                if (!datasourceFactory.checkTableExists(entityName)) {
                    datasourceFactory.checkAndAddTable(entityName)
                }
                if (!datasourceFactory.checkTableExists(entityName)) {
                    ec.message.addError("Database table NS_RESTLET_CONFIG is missing and could not be created automatically.")
                }
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <service-call name="store#darpan.reconciliation.NsRestletConfig" in-map="endpointMap"/>
            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>
            <message>Saved NS endpoint config ${nsRestletConfigId} using auth ${nsAuthConfigId}.</message>
        </actions>
        <default-response url=".">
            <parameter name="editNsRestletConfigId" from="nsRestletConfigId"/>
        </default-response>
    </transition>

    <pre-actions>
        <script><![CDATA[
            def authCfgList = []
            def authById = [:]
            ec.entity.find("darpan.reconciliation.NsAuthConfig")
                    .useCache(false)
                    .orderBy(["description", "nsAuthConfigId"])
                    .list()
                    ?.each { cfg ->
                        String label = "${cfg.nsAuthConfigId}" + (cfg.description ? " - ${cfg.description}" : "")
                        authCfgList.add([
                                nsAuthConfigId: cfg.nsAuthConfigId,
                                optionLabel   : label
                        ])
                        authById[cfg.nsAuthConfigId] = [
                                description: cfg.description,
                                authType   : cfg.authType,
                                isActive   : cfg.isActive
                        ]
                    }
            context.nsAuthOptions = authCfgList

            def endpointConfigs = []
            ec.entity.find("darpan.reconciliation.NsRestletConfig")
                    .useCache(false)
                    .orderBy(["description", "nsRestletConfigId"])
                    .list()
                    ?.each { cfg ->
                        def authMeta = authById[cfg.nsAuthConfigId]
                        endpointConfigs.add([
                                nsRestletConfigId    : cfg.nsRestletConfigId,
                                description          : cfg.description,
                                endpointUrl          : cfg.endpointUrl,
                                httpMethod           : cfg.httpMethod,
                                nsAuthConfigId       : cfg.nsAuthConfigId,
                                authDescription      : authMeta?.description,
                                authType             : authMeta?.authType,
                                connectTimeoutSeconds: cfg.connectTimeoutSeconds,
                                readTimeoutSeconds   : cfg.readTimeoutSeconds,
                                isActive             : cfg.isActive
                        ])
                    }
            context.nsRestletConfigs = endpointConfigs
        ]]>        </script>

        <if condition="editNsRestletConfigId">
            <script><![CDATA[
                String cfgId = editNsRestletConfigId?.toString()?.trim()
                if (cfgId) {
                    def cfg = ec.entity.find("darpan.reconciliation.NsRestletConfig")
                            .condition("nsRestletConfigId", cfgId)
                            .useCache(false)
                            .one()
                    if (cfg) {
                        context.nsRestletConfigId = cfg.nsRestletConfigId
                        context.nsDescription = cfg.description
                        context.nsEndpointUrl = cfg.endpointUrl
                        context.nsHttpMethod = cfg.httpMethod ?: "POST"
                        context.nsAuthConfigId = cfg.nsAuthConfigId
                        context.nsHeadersJson = cfg.headersJson
                        context.nsConnectTimeoutSeconds = cfg.connectTimeoutSeconds ?: 30
                        context.nsReadTimeoutSeconds = cfg.readTimeoutSeconds ?: 60
                        context.nsIsActive = cfg.isActive ?: "Y"
                    }
                }
            ]]>            </script>
        </if>
    </pre-actions>

    <widgets>
        <container style="container">
            <container style="page-header">
                <label text="NetSuite Endpoint Settings" type="h2"/>
                <label text="Configure NetSuite endpoints and attach an auth profile. One auth profile can be reused across multiple endpoints." type="p" style="text-muted"/>
            </container>

            <section name="NsEndpointConfigSection">
                <widgets>
                    <label text="NetSuite Endpoints" type="h4"/>
                    <label text="${nsRestletConfigId ? 'Edit NS Endpoint Config' : 'Add NS Endpoint Config'}" type="p" style="text-muted"/>
                    <form-single name="NsEndpointConfigForm" transition="saveNsRestletConfig">
                        <field name="nsRestletConfigId">
                            <default-field title="Endpoint Config ID">
                                <text-line size="30"/>
                            </default-field>
                        </field>
                        <field name="nsDescription">
                            <default-field title="Description">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="nsEndpointUrl">
                            <default-field title="Endpoint URL">
                                <text-line size="100"/>
                            </default-field>
                        </field>
                        <field name="nsHttpMethod">
                            <default-field title="HTTP Method">
                                <drop-down allow-empty="false">
                                    <option key="POST" text="POST"/>
                                    <option key="PUT" text="PUT"/>
                                    <option key="GET" text="GET"/>
                                </drop-down>
                            </default-field>
                        </field>
                        <field name="nsAuthConfigId">
                            <default-field title="Auth Config">
                                <drop-down>
                                    <option key="" text="Select auth config"/>
                                    <list-options list="nsAuthOptions" key="${nsAuthConfigId}" text="${optionLabel}"/>
                                </drop-down>
                            </default-field>
                        </field>
                        <field name="nsHeadersJson">
                            <default-field title="Headers JSON">
                                <text-area cols="80" rows="3"/>
                            </default-field>
                        </field>
                        <field name="nsConnectTimeoutSeconds">
                            <default-field title="Connect Timeout (seconds)">
                                <text-line size="6" default-value="30"/>
                            </default-field>
                        </field>
                        <field name="nsReadTimeoutSeconds">
                            <default-field title="Read Timeout (seconds)">
                                <text-line size="6" default-value="60"/>
                            </default-field>
                        </field>
                        <field name="nsIsActive">
                            <default-field title="Active?">
                                <check checked-value="Y" unchecked-value="N"/>
                            </default-field>
                        </field>
                        <field name="saveNsConfigButton">
                            <default-field title="">
                                <submit text="Save NS Endpoint Config" btn-type="primary"/>
                            </default-field>
                        </field>

                        <field-layout>
                            <field-row>
                                <field-ref name="nsRestletConfigId"/>
                                <field-ref name="nsDescription"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsEndpointUrl"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsHttpMethod"/>
                                <field-ref name="nsAuthConfigId"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="nsHeadersJson"/>
                            </field-row-big>
                            <field-row>
                                <field-ref name="nsConnectTimeoutSeconds"/>
                                <field-ref name="nsReadTimeoutSeconds"/>
                                <field-ref name="nsIsActive"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="saveNsConfigButton"/>
                            </field-row-big>
                        </field-layout>
                    </form-single>
                </widgets>
            </section>

            <container type="hr"/>

            <section name="NsRestletConfigListSection">
                <widgets>
                    <label text="Existing NS Endpoint Configs" type="h4"/>
                    <section name="NoNsConfigs" condition="!nsRestletConfigs">
                        <widgets>
                            <label text="No NS endpoint configs found." type="p" style="text-muted"/>
                        </widgets>
                    </section>
                    <section name="NsConfigsTable" condition="nsRestletConfigs">
                        <widgets>
                            <form-list name="NsRestletConfigsList" list="nsRestletConfigs" skip-form="true" paginate="true" paginate-always-show="true" style="table table-striped table-condensed">
                                <field name="nsRestletConfigId">
                                    <header-field title="Endpoint ID"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="description">
                                    <header-field title="Description"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="endpointUrl">
                                    <header-field title="Endpoint URL"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="httpMethod">
                                    <header-field title="Method"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="nsAuthConfigId">
                                    <header-field title="Auth Config"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="authType">
                                    <header-field title="Auth Type"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="isActive">
                                    <header-field title="Active"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="actions">
                                    <header-field title=""/>
                                    <default-field>
                                        <link url="." text="Edit" link-type="anchor-button" btn-type="info" style="btn-xs">
                                            <parameter name="editNsRestletConfigId" from="nsRestletConfigId"/>
                                        </link>
                                    </default-field>
                                </field>
                            </form-list>
                        </widgets>
                    </section>
                </widgets>
            </section>
        </container>
    </widgets>
</screen>
