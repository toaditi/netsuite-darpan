<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd" default-menu-title="NetSuite Auth" require-authentication="false">

    <parameter name="editNsAuthConfigId"/>

    <transition name="saveNsAuthConfig">
        <actions>
            <set field="nsAuthConfigId" from="nsAuthConfigId?.trim()"/>
            <set field="nsAuthDescription" from="nsAuthDescription?.trim()"/>
            <set field="nsAuthType" from="nsAuthType?.trim()?.toUpperCase()"/>
            <set field="nsUsername" from="nsUsername?.trim()"/>
            <set field="nsTokenUrl" from="nsTokenUrl?.trim()"/>
            <set field="nsClientId" from="nsClientId?.trim()"/>
            <set field="nsCertId" from="nsCertId?.trim()"/>
            <set field="nsScope" from="nsScope?.trim()"/>
            <set field="nsPrivateKeyPem" from="nsPrivateKeyPem?.trim()"/>
            <set field="nsIsActive" from="nsIsActive?.trim()?.toUpperCase()"/>

            <if condition="!nsAuthConfigId">
                <message type="error" text="Auth Config ID is required."/>
                <return error="true"/>
            </if>
            <if condition="!['NONE','BASIC','BEARER','OAUTH2_M2M_JWT'].contains(nsAuthType ?: 'NONE')">
                <message type="error" text="Auth Type must be NONE, BASIC, BEARER, or OAUTH2_M2M_JWT."/>
                <return error="true"/>
            </if>
            <if condition="(nsAuthType ?: 'NONE') == 'BASIC' &amp;&amp; !nsUsername">
                <message type="error" text="Username is required for BASIC auth."/>
                <return error="true"/>
            </if>
            <if condition="(nsAuthType ?: 'NONE') == 'BEARER' &amp;&amp; !nsApiToken &amp;&amp; !nsPassword">
                <message type="warning" text="Provide API Token (or password fallback) for BEARER auth."/>
            </if>

            <script><![CDATA[
                def existingAuth = ec.entity.find("darpan.reconciliation.NsAuthConfig")
                        .condition("nsAuthConfigId", nsAuthConfigId)
                        .useCache(false)
                        .one()

                String resolvedAuthType = nsAuthType ?: 'NONE'
                if (resolvedAuthType == 'OAUTH2_M2M_JWT') {
                    if (!nsTokenUrl) ec.message.addError("Token URL is required for OAUTH2_M2M_JWT auth.")
                    if (!nsClientId) ec.message.addError("Client ID is required for OAUTH2_M2M_JWT auth.")
                    if (!nsCertId) ec.message.addError("Cert ID is required for OAUTH2_M2M_JWT auth.")
                    if (!nsPrivateKeyPem && !existingAuth?.privateKeyPem) {
                        ec.message.addError("Private Key PEM is required for OAUTH2_M2M_JWT auth.")
                    }
                }

                Map authMap = [
                        nsAuthConfigId: nsAuthConfigId,
                        description   : nsAuthDescription,
                        authType      : resolvedAuthType,
                        username      : nsUsername,
                        tokenUrl      : nsTokenUrl,
                        clientId      : nsClientId,
                        certId        : nsCertId,
                        scope         : nsScope ?: 'restlets rest_webservices',
                        isActive      : nsIsActive ?: 'Y'
                ]
                if (nsPassword) authMap.password = nsPassword
                if (nsApiToken) authMap.apiToken = nsApiToken
                if (nsPrivateKeyPem) authMap.privateKeyPem = nsPrivateKeyPem
                if (!nsPassword && existingAuth?.password) authMap.password = existingAuth.password
                if (!nsApiToken && existingAuth?.apiToken) authMap.apiToken = existingAuth.apiToken
                if (!nsPrivateKeyPem && existingAuth?.privateKeyPem) authMap.privateKeyPem = existingAuth.privateKeyPem
                context.authMap = authMap
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <script><![CDATA[
                String entityName = "darpan.reconciliation.NsAuthConfig"
                String groupName = ec.entity.getEntityGroupName(entityName)
                def datasourceFactory = groupName ? ec.entity.getDatasourceFactory(groupName) : null
                if (!datasourceFactory) {
                    ec.message.addError("Could not resolve datasource for ${entityName}.")
                    return
                }
                if (!datasourceFactory.checkTableExists(entityName)) {
                    datasourceFactory.checkAndAddTable(entityName)
                }
                if (!datasourceFactory.checkTableExists(entityName)) {
                    ec.message.addError("Database table NS_AUTH_CONFIG is missing and could not be created automatically.")
                }
            ]]>            </script>

            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>

            <service-call name="store#darpan.reconciliation.NsAuthConfig" in-map="authMap"/>
            <if condition="ec.message.hasError()">
                <return error="true"/>
            </if>
            <message>Saved NS Auth config ${nsAuthConfigId}.</message>
        </actions>
        <default-response url=".">
            <parameter name="editNsAuthConfigId" from="nsAuthConfigId"/>
        </default-response>
    </transition>

    <pre-actions>
        <script><![CDATA[
            def authConfigs = []
            ec.entity.find("darpan.reconciliation.NsAuthConfig")
                    .useCache(false)
                    .orderBy(["description", "nsAuthConfigId"])
                    .list()
                    ?.each { cfg ->
                        authConfigs.add([
                                nsAuthConfigId    : cfg.nsAuthConfigId,
                                description       : cfg.description,
                                authType          : cfg.authType,
                                username          : cfg.username,
                                tokenUrl          : cfg.tokenUrl,
                                clientId          : cfg.clientId,
                                certId            : cfg.certId,
                                isActive          : cfg.isActive,
                                hasPassword       : !!cfg.password,
                                hasApiToken       : !!cfg.apiToken,
                                hasPrivateKeyPem  : !!cfg.privateKeyPem
                        ])
                    }
            context.nsAuthConfigs = authConfigs
        ]]>        </script>

        <if condition="editNsAuthConfigId">
            <script><![CDATA[
                String cfgId = editNsAuthConfigId?.toString()?.trim()
                if (cfgId) {
                    def cfg = ec.entity.find("darpan.reconciliation.NsAuthConfig")
                            .condition("nsAuthConfigId", cfgId)
                            .useCache(false)
                            .one()
                    if (cfg) {
                        context.nsAuthConfigId = cfg.nsAuthConfigId
                        context.nsAuthDescription = cfg.description
                        context.nsAuthType = cfg.authType ?: "NONE"
                        context.nsUsername = cfg.username
                        context.nsTokenUrl = cfg.tokenUrl
                        context.nsClientId = cfg.clientId
                        context.nsCertId = cfg.certId
                        context.nsScope = cfg.scope ?: "restlets rest_webservices"
                        context.nsIsActive = cfg.isActive ?: "Y"
                        context.nsHasPassword = !!cfg.password
                        context.nsHasApiToken = !!cfg.apiToken
                        context.nsHasPrivateKeyPem = !!cfg.privateKeyPem
                    }
                }
            ]]>            </script>
        </if>
    </pre-actions>

    <widgets>
        <container style="container">
            <container style="page-header">
                <label text="NetSuite Auth Settings" type="h2"/>
                <label text="Create reusable NetSuite auth profiles; each profile can be linked to multiple endpoint configs." type="p" style="text-muted"/>
            </container>

            <section name="NsAuthConfigSection">
                <widgets>
                    <label text="NetSuite Auth" type="h4"/>
                    <label text="${nsAuthConfigId ? 'Edit NS Auth Config' : 'Add NS Auth Config'}" type="p" style="text-muted"/>
                    <label text="Stored Password: ${nsHasPassword ? 'Yes' : 'No'} | Stored API Token: ${nsHasApiToken ? 'Yes' : 'No'} | Stored Private Key: ${nsHasPrivateKeyPem ? 'Yes' : 'No'}" condition="nsAuthConfigId" type="p" style="text-info"/>
                    <form-single name="NsAuthConfigForm" transition="saveNsAuthConfig">
                        <field name="nsAuthConfigId">
                            <default-field title="Auth Config ID">
                                <text-line size="30"/>
                            </default-field>
                        </field>
                        <field name="nsAuthDescription">
                            <default-field title="Description">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="nsAuthType">
                            <default-field title="Auth Type">
                                <drop-down allow-empty="false">
                                    <option key="NONE" text="None"/>
                                    <option key="BASIC" text="Basic"/>
                                    <option key="BEARER" text="Bearer"/>
                                    <option key="OAUTH2_M2M_JWT" text="OAuth2 M2M JWT"/>
                                </drop-down>
                            </default-field>
                        </field>
                        <field name="nsUsername">
                            <default-field title="Username (Basic Auth)">
                                <text-line size="40"/>
                            </default-field>
                        </field>
                        <field name="nsPassword">
                            <default-field title="Password (leave blank to keep existing)">
                                <password size="40"/>
                            </default-field>
                        </field>
                        <field name="nsApiToken">
                            <default-field title="API Token (leave blank to keep existing)">
                                <password size="40"/>
                            </default-field>
                        </field>
                        <field name="nsTokenUrl">
                            <default-field title="Token URL (OAuth2 M2M JWT)">
                                <text-line size="100"/>
                            </default-field>
                        </field>
                        <field name="nsClientId">
                            <default-field title="Client ID (OAuth2 M2M JWT)">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="nsCertId">
                            <default-field title="Cert ID / KID (OAuth2 M2M JWT)">
                                <text-line size="60"/>
                            </default-field>
                        </field>
                        <field name="nsScope">
                            <default-field title="Scope (OAuth2 M2M JWT)">
                                <text-line size="60" default-value="restlets rest_webservices"/>
                            </default-field>
                        </field>
                        <field name="nsPrivateKeyPem">
                            <default-field title="Private Key PEM (leave blank to keep existing)">
                                <text-area cols="80" rows="6"/>
                            </default-field>
                        </field>
                        <field name="nsIsActive">
                            <default-field title="Active?">
                                <check checked-value="Y" unchecked-value="N"/>
                            </default-field>
                        </field>
                        <field name="saveAuthConfigButton">
                            <default-field title="">
                                <submit text="Save NS Auth Config" btn-type="primary"/>
                            </default-field>
                        </field>

                        <field-layout>
                            <field-row>
                                <field-ref name="nsAuthConfigId"/>
                                <field-ref name="nsAuthDescription"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsAuthType"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsUsername"/>
                                <field-ref name="nsPassword"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsApiToken"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsTokenUrl"/>
                            </field-row>
                            <field-row>
                                <field-ref name="nsClientId"/>
                                <field-ref name="nsCertId"/>
                                <field-ref name="nsScope"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="nsPrivateKeyPem"/>
                            </field-row-big>
                            <field-row>
                                <field-ref name="nsIsActive"/>
                            </field-row>
                            <field-row-big>
                                <field-ref name="saveAuthConfigButton"/>
                            </field-row-big>
                        </field-layout>
                    </form-single>
                </widgets>
            </section>

            <container type="hr"/>

            <section name="NsAuthConfigListSection">
                <widgets>
                    <label text="Existing NS Auth Configs" type="h4"/>
                    <section name="NoNsAuthConfigs" condition="!nsAuthConfigs">
                        <widgets>
                            <label text="No NS auth configs found." type="p" style="text-muted"/>
                        </widgets>
                    </section>
                    <section name="NsAuthConfigsTable" condition="nsAuthConfigs">
                        <widgets>
                            <form-list name="NsAuthConfigsList" list="nsAuthConfigs" skip-form="true" paginate="true" paginate-always-show="true" style="table table-striped table-condensed">
                                <field name="nsAuthConfigId">
                                    <header-field title="Auth Config ID"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="description">
                                    <header-field title="Description"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="authType">
                                    <header-field title="Auth Type"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="username">
                                    <header-field title="Username"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="isActive">
                                    <header-field title="Active"/>
                                    <default-field><display/></default-field>
                                </field>
                                <field name="hasPassword">
                                    <header-field title="Password?"/>
                                    <default-field>
                                        <label text="${hasPassword ? 'Yes' : 'No'}" type="span"/>
                                    </default-field>
                                </field>
                                <field name="hasApiToken">
                                    <header-field title="API Token?"/>
                                    <default-field>
                                        <label text="${hasApiToken ? 'Yes' : 'No'}" type="span"/>
                                    </default-field>
                                </field>
                                <field name="hasPrivateKeyPem">
                                    <header-field title="Private Key?"/>
                                    <default-field>
                                        <label text="${hasPrivateKeyPem ? 'Yes' : 'No'}" type="span"/>
                                    </default-field>
                                </field>
                                <field name="actions">
                                    <header-field title=""/>
                                    <default-field>
                                        <link url="." text="Edit" link-type="anchor-button" btn-type="info" style="btn-xs">
                                            <parameter name="editNsAuthConfigId" from="nsAuthConfigId"/>
                                        </link>
                                    </default-field>
                                </field>
                            </form-list>
                        </widgets>
                    </section>
                </widgets>
            </section>
        </container>
    </widgets>
</screen>
